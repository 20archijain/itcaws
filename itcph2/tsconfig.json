{
  "compileOnSave": false,
  "angularCompilerOptions": {
    "disableTypeScriptVersionCheck": true,
    "strictTemplates": true
  },
  "compilerOptions": {
    // Base directory to resolve non-relative module names.
    "baseUrl": "./",
    // Redirect output structure to the directory.
    "outDir": "./dist/out-tsc",
    // Generates corresponding '.map' file.
    "sourceMap": true,
    // Generates corresponding d.ts files.
    "declaration": false,
    "esModuleInterop": true,
    // Emit design-type metadata for decorated declarations in source.
    "emitDecoratorMetadata": true,
    // Enables experimental support for ES7 decorators.
    "experimentalDecorators": true,
    // specify module code generation: 'none', 'commonjs', 'amd', 'system', 'umd', 'es2015' or 'esnext'.
    // "ES6" and "ES2015" values may be used when targeting "ES5" or lower.
    "module": "ES2022",
    // Determine how modules get resolved. Either "Node" for Node.js/io.js style resolution, or "Classic". (TypeScript pre 1.6) .
    "moduleResolution": "bundler",
    // Import emit helpers (e.g. '__extends', '__rest', etc..) from tslib. Requires TypeScript version 2.1 or later.
    "importHelpers": true,
    // pecify ECMAScript target version.
    // Permitted values are 'es3', 'es5', 'es6', 'es2015', 'es2016', 'es2017', 'es2018', 'es2019', 'es2020' or 'esnext'.
    "target": "ES2022",
    // Specify list of directories for type definition files to be included. Requires TypeScript version 2.0 or later.
    "typeRoots": [
      "node_modules/@types"
    ],
    // Specify library file to be included in the compilation. Requires TypeScript version 2.0 or later.
    "lib": [
      "ES2022",
      "dom"
    ],
    "useDefineForClassFields": false
  }
}
