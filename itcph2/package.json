{
  "name": "itcawsportalitcph2",
  "version": "0.0.0",
  "scripts": {
    "start": "ng serve",
    "start:proxy": "ng serve --configuration=proxy",
    "start:proxyhost": "ng serve --configuration=proxy --host=0.0.0.0",
    "start:prodlocal": "ng serve --configuration=prodLocal",
    "build:local": "ng build --configuration=test",
    "build": "npm run copy_dist_services && ng build --configuration=production",
    "copy_dist_services": "rmdir /s /q \"src/services\" && xcopy \"dist/services\" \"src/services\\\" /s /e /y",
    "test": "ng test",
    "lint": "ng lint",
    "postlint": "sass-lint --verbose --no-exit && phpcs --ignore=.js,.css --standard=../phpcs_ruleset.xml dist/services/",
    "e2e": "ng e2e"
  },
  "private": true,
