{
  "name": "itcawsportalitcph2",
  "version": "0.0.0",
  "scripts": {
    "start": "ng serve",
    "start:proxy": "ng serve --configuration=proxy",
    "start:proxyhost": "ng serve --configuration=proxy --host=0.0.0.0",
    "start:prodlocal": "ng serve --configuration=prodLocal",
    "build:local": "npm run copy_dist && ng build --configuration=test",
    "build": "npm run copy_dist && ng build --configuration=production",
    "copy_dist": "npm run copy_dist_services && npm run copy_dist_php_config",
    "copy_dist_php_config": "robocopy dist\\browser src .htaccess /NFL /NDL /NJH /NJS /nc /ns /np & robocopy dist\\browser src .user.ini /NFL /NDL /NJH /NJS /nc /ns /np & robocopy dist\\browser src php.ini /NFL /NDL /NJH /NJS /nc /ns /np || exit 0",
    "copy_dist_services": "robocopy dist\\browser\\services src\\services /E /NFL /NDL || exit 0",
    "test": "ng test",
    "lint": "ng lint",
    "postlint": "sass-lint --verbose --no-exit && phpcs --ignore=.js,.css --standard=../phpcs_ruleset.xml dist/",
    "e2e": "ng e2e"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.21",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.21",
    "@angular/compiler": "^19.2.21",
    "@angular/core": "^19.2.21",
    "@angular/forms": "^19.2.21",
    "@angular/google-maps": "^19.2.19",
    "@angular/localize": "^19.2.21",
    "@angular/platform-browser": "^19.2.21",
    "@angular/platform-browser-dynamic": "^19.2.21",
    "@angular/router": "^19.2.21",
    "@ng-bootstrap/ng-bootstrap": "^18.0.0",
    "@ng-select/ng-select": "^14.0.0",
    "@ngx-translate/core": "^16.0.0",
    "@ngx-translate/http-loader": "^8.0.0",
    "@swimlane/ngx-charts": "^22.0.0",
    "apexcharts": "^3.53.0",
    "bootstrap": "5.3.3",
    "file-saver": "^2.0.5",
    "highcharts": "^11.0.0",
    "highcharts-angular": "^4.0.0",
    "html2canvas": "^1.4.1",
    "ifvisible.js": "^1.0.6",
    "install": "^0.13.0",
    "jquery": "^3.4.1",
    "jspdf": "^3.0.0",
    "jspdf-autotable": "^5.0.0",
    "leaflet": "^1.9.4",
    "moment": "^2.29.1",
    "ng-click-outside2": "^12.0.0",
    "ngx-scrollbar": "^16.0.0",
    "ngx-toastr": "^19.0.0",
    "npm": "^9.0.0",
    "ramda": "0.30.1",
    "rxjs": "~7.8.0",
    "rxjs-compat": "^6.5.2",
    "sweetalert2": "^11.6.13",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.24",
    "@angular/cli": "^19.2.24",
    "@angular/compiler-cli": "^19.2.21",
    "@angular/language-service": "^19.2.21",
    "@types/file-saver": "^2.0.7",
    "@types/leaflet": "^1.9.21",
    "@types/d3-shape": "^3.1.8",
    "@types/jquery": "^3.3.30",
    "@types/node": "~8.9.4",
    "@types/ramda": "^0.30.1",
    "angular-eslint": "19.4.0",
    "eslint": "^9.26.0",
    "ts-node": "~8.3.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.58.2"
  }
}
