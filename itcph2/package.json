{
  "name": "itcawsportalitcph2",
  "version": "0.0.0",
  "scripts": {
    "start": "ng serve",
    "start:proxy": "ng serve --configuration=proxy",
    "start:proxyhost": "ng serve --configuration=proxy --host=0.0.0.0",
    "start:prodlocal": "ng serve --configuration=prodLocal",
    "build:local": "npm run copy_dist && ng build --configuration=test",
    "build": "npm run copy_dist && ng build --configuration=production && npm run cleanup_src",
    "copy_dist": "npm run copy_dist_services && npm run copy_dist_php_config",
    "copy_dist_services": "robocopy dist\\browser\\services src\\services /E /NFL /NDL || exit 0",
    "copy_dist_php_config": "robocopy dist\\browser src .htaccess /NFL /NDL /NJH /NJS /nc /ns /np & robocopy dist\\browser src .user.ini /NFL /NDL /NJH /NJS /nc /ns /np & robocopy dist\\browser src php.ini /NFL /NDL /NJH /NJS /nc /ns /np || exit 0",
    "cleanup_src": "npm run clean_services && npm run clean_php_config",
    "clean_services": "rmdir /S /Q src\\services",
    "clean_php_config": "del /Q src\\.htaccess src\\.user.ini src\\php.ini",
    "test": "ng test",
    "test-coverage": "ng test --code-coverage",
    "lint": "ng lint",
    "postlint": "npm run scss_lint_using_sass_lint && npm run scss_lint_using_stylelint && npm run php_lint_using_php_codesniffer && npm run php_lint_using_php_cs_fixer",
    "lint:fix": "npm run fix_ts_lint && npm run fix_scss_lint_using_stylelint && npm run fix_php_lint_using_php_codesniffer && npm run fix_php_lint_using_php_cs_fixer",
    "scss_lint_using_sass_lint": "sass-lint --verbose --no-exit",
    "scss_lint_using_stylelint": "npx stylelint \"**/*.scss\"",
    "php_lint_using_php_codesniffer": "phpcs --cache --ignore=.js,.css --standard=../phpcs_ruleset.xml dist/browser/",
    "php_lint_using_php_cs_fixer": "php-cs-fixer fix dist/browser/ --config=.php-cs-fixer.php --using-cache=yes --dry-run",
    "fix_ts_lint": "ng lint --fix",
    "fix_scss_lint_using_stylelint": "npx stylelint \"**/*.scss\" --fix",
    "fix_php_lint_using_php_codesniffer": "phpcbf --ignore=.js,.css --standard=../phpcs_ruleset.xml dist/browser/",
    "fix_php_lint_using_php_cs_fixer": "php-cs-fixer fix dist/browser/ --config=.php-cs-fixer.php --using-cache=yes",
    "phpstan": "php ../uproots/php_libs/vendor/bin/phpstan analyse -c phpstan.neon --memory-limit=1G"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.21",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.21",
    "@angular/compiler": "^19.2.21",
    "@angular/core": "^19.2.21",
    "@angular/forms": "^19.2.21",
    "@angular/google-maps": "^19.2.19",
    "@angular/localize": "^19.2.21",
    "@angular/platform-browser": "^19.2.21",
    "@angular/platform-browser-dynamic": "^19.2.21",
    "@angular/router": "^19.2.21",
    "@ng-bootstrap/ng-bootstrap": "^18.0.0",
    "@ng-select/ng-select": "^14.0.0",
    "@ngx-translate/core": "^16.0.0",
    "@ngx-translate/http-loader": "^8.0.0",
    "@swimlane/ngx-charts": "^22.0.0",
    "apexcharts": "^3.53.0",
    "bootstrap": "5.3.3",
    "file-saver": "^2.0.5",
    "highcharts": "^11.0.0",
    "highcharts-angular": "^4.0.0",
    "html2canvas": "^1.4.1",
    "ifvisible.js": "^1.0.6",
    "install": "^0.13.0",
    "jquery": "^3.4.1",
    "jspdf": "^3.0.0",
    "jspdf-autotable": "^5.0.0",
    "leaflet": "^1.9.4",
    "moment": "^2.29.1",
    "ng-click-outside2": "^12.0.0",
    "ngx-scrollbar": "^16.0.0",
    "ngx-toastr": "^19.0.0",
    "npm": "^9.0.0",
    "ramda": "0.30.1",
    "rxjs": "~7.8.0",
    "rxjs-compat": "^6.5.2",
    "sweetalert2": "^11.6.13",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.24",
    "@angular/cli": "^19.2.24",
    "@angular/compiler-cli": "^19.2.21",
    "@angular/language-service": "^19.2.21",
    "@types/d3-shape": "^3.1.8",
    "@types/file-saver": "^2.0.7",
    "@types/jasmine": "~5.1.0",
    "@types/jquery": "^3.3.30",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^6.14.13",
    "@types/ramda": "^0.30.1",
    "angular-eslint": "19.4.0",
    "eslint": "^9.26.0",
    "jasmine-core": "~5.4.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "karma-spec-reporter": "^0.0.36",
    "ts-node": "~8.3.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.58.2"
  }
}
